<!-- ============================================================
     camera.xml — RGBカメラ単体
     実測値(2026-07-03): 70 x 30 x 30mm, 50g, プラスチック筐体
     TILT軸からカメラ重心までのオフセット55mm
     (ブラケット接着面40mm + カメラ半長15mm、ユーザー算出)は
     統合XML側でpos指定する。ここではカメラ本体のみ定義。
     ============================================================ -->
<mujocoinclude>
  <body name="camera_body" pos="0.055 0 0">
    <geom name="camera_geom" type="box"
          size="0.035 0.015 0.015"
          mass="0.050" rgba="0.15 0.65 0.35 1"/>
  </body>
</mujocoinclude>
